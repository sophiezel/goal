{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "goal-pipeline/schemas/review.schema.json",
  "title": "Review stage handoff",
  "type": "object",
  "required": ["stage", "schema_version", "result", "gate"],
  "properties": {
    "stage": { "const": "review" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "result": { "enum": ["pass", "not_pass"] },
    "artifact_paths": { "type": "array", "items": { "type": "string" } },
    "gate": {
      "type": "object",
      "required": ["script", "version", "passed_at"],
      "properties": {
        "script": { "type": "string" },
        "version": { "type": "integer" },
        "passed_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": true
}
